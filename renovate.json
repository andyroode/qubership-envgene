{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["dockerfile", "pip_requirements", "custom.regex", "maven"],
  "vulnerabilityAlerts": {
    "groupName": "qubership-envgene-deps",
    "labels": ["security"],
    "commitMessageSuffix": "",
    "minimumReleaseAge": null
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Apk pins (apk add ... =version) in any Dockerfile via Repology",
      "managerFilePatterns": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "(?:^|\\r?\\n)\\s+(?<pkg>[a-z0-9][a-z0-9+._-]*)=(?<currentValue>[^\\s\\\\]+)\\s*(?:\\\\)?\\s*(?:\\r?\\n|$)",
        "(?:^|\\r?\\n)ARG JAVA_PACKAGE=(?<pkg>[^=]+)=(?<currentValue>\\S+)\\s*(?:\\r?\\n|$)"
      ],
      "datasourceTemplate": "repology",
      "packageNameTemplate": "alpine_3_19/{{{pkg}}}",
      "versioningTemplate": "loose"
    }
  ],
  "semanticCommits": "disabled",
  "commitMessagePrefix": "feat:",
  "schedule": ["* * 1,15 * *"],
  "packageRules": [
    {
      "description": "Only semver patch (Z in X.Y.Z) for Docker images, pip requirements, and Maven (pom.xml)",
      "matchManagers": ["dockerfile", "pip_requirements", "maven"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "description": "Allow minor/major when Renovate is applying a vulnerability fix (patch-only would block the fix)",
      "matchJsonata": ["$exists(vulnerabilityFixVersion)"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": true
    },
    {
      "description": "Full semver (X.Y.Z) for qubership-envgene-base-modules base image",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["ghcr.io/netcracker/qubership-envgene-base-modules"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": true
    },
    {
      "description": "Apk pins (Repology regex): only patch updates",
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["repology"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "description": "Do not bump cython (repo keeps cython<3 in constraint.txt)",
      "matchPackageNames": ["cython"],
      "enabled": false
    },
    {
      "description": "Single PR: Docker base images, Python reqs, Alpine apk pins, Maven, and grouped vulnerability fixes",
      "matchManagers": ["dockerfile", "pip_requirements", "custom.regex", "maven"],
      "groupName": "qubership-envgene-deps",
      "commitMessageAction": "update",
      "commitMessageTopic": "dependencies",
      "commitMessageExtra": " via Renovate"
    }
  ]
}
