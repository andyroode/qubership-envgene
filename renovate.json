{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":disableDependencyDashboard"],
  "separateMajorMinor": false,
  "separateMinorPatch": false,
  "prConcurrentLimit": 1,
  "branchConcurrentLimit": 1,
  "dependencyDashboard": false,
  "dependencyDashboardApproval": false,
  "dependencyDashboardAutoclose": true,
  "suppressNotifications": ["configErrorIssue"],
  "lockFileMaintenance": {
    "enabled": false
  },
  "enabledManagers": [
    "dockerfile",
    "pip_requirements",
    "pep621",
    "maven",
    "github-actions",
    "custom.regex"
  ],
  "pip_requirements": {
    "managerFilePatterns": [
      "(^|/)requirements[^/]*\\.txt$",
      "(^|/)build/[^/]+/requirements\\.txt$"
    ]
  },
  "pep621": {
    "managerFilePatterns": ["(^|/)pyproject\\.toml$"]
  },
  "github-actions": {
    "managerFilePatterns": [
      "(^|/)\\.github/(?:workflows|actions)/.+\\.ya?ml$",
      "(^|/)github_workflows/.+\\.ya?ml$"
    ]
  },
  "hostRules": [
    {
      "description": "GitHub Packages Maven (credentials: Mend hostRules / PAT with read:packages)",
      "hostType": "maven",
      "matchHost": "maven.pkg.github.com"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Alpine apk pins in Dockerfiles (Repology alpine_3_19)",
      "managerFilePatterns": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "(?:^|\\r?\\n)\\s+(?<pkg>[a-z0-9][a-z0-9+._-]*)=(?<currentValue>[^\\s\\\\]+)\\s*(?:\\\\)?\\s*(?:\\r?\\n|$)",
        "(?:^|\\r?\\n)ARG JAVA_PACKAGE=(?<pkg>[^=]+)=(?<currentValue>\\S+)\\s*(?:\\r?\\n|$)"
      ],
      "datasourceTemplate": "repology",
      "packageNameTemplate": "alpine_3_19/{{{pkg}}}",
      "versioningTemplate": "loose"
    }
  ],
  "semanticCommits": "disabled",
  "commitMessagePrefix": "feat:",
  "commitMessageAction": "UPDATE",
  "commitMessageTopic": "QUBERSHIP-ENVGENE DEPENDENCIES",
  "commitMessageExtra": " VIA RENOVATE",
  "schedule": ["* * 1,15 * *"],
  "packageRules": [
    {
      "description": "Netcracker Qubership JARs published to GitHub Packages by CI",
      "matchManagers": ["maven"],
      "matchPackageNames": ["/^org\\.qubership\\.cloud\\.devops(\\.cli)?:/"],
      "registryUrls": ["https://maven.pkg.github.com/Netcracker/qubership-envgene"]
    },
    {
      "description": "Jenkins plugin coordinates (repo.jenkins-ci.org)",
      "matchManagers": ["maven"],
      "matchPackageNames": ["/^io\\.jenkins\\.plugins:/"],
      "registryUrls": ["https://repo.jenkins-ci.org/public"]
    },
    {
      "description": "Patch-only for all managers (no minor or major upgrades)",
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "description": "GHCR base image: allow major/minor/patch tag bumps (internal base modules)",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["ghcr.io/netcracker/qubership-envgene-base-modules"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "enabled": true
    },
    {
      "description": "Docker: skip digest bumps (same tag, new image) - not semver patch",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "description": "Do not bump cython (constraint.txt uses cython<3)",
      "matchPackageNames": ["cython"],
      "enabled": false
    },
    {
      "description": "One grouped PR for all dependency managers",
      "matchManagers": [
        "dockerfile",
        "pip_requirements",
        "pep621",
        "custom.regex",
        "maven",
        "github-actions"
      ],
      "groupName": "qubership-envgene-deps",
      "commitMessageAction": "UPDATE",
      "commitMessageTopic": "QUBERSHIP-ENVGENE DEPENDENCIES",
      "commitMessageExtra": " VIA RENOVATE"
    }
  ]
}
