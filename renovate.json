{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["dockerfile", "pip_requirements", "custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Apk pins (apk add … =version) in any Dockerfile via Repology",
      "managerFilePatterns": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "^\\s+(?<pkg>(?!export)[a-z0-9][a-z0-9+._-]*)=(?<currentValue>[^\\s\\\\]+)\\s*(?:\\\\)?\\s*$",
        "^ARG JAVA_PACKAGE=(?<pkg>[^=]+)=(?<currentValue>\\S+)\\s*$"
      ],
      "datasourceTemplate": "repology",
      "packageNameTemplate": "alpine_3_19/{{{pkg}}}",
      "versioningTemplate": "loose"
    }
  ],
  "semanticCommits": "disabled",
  "commitMessagePrefix": "feat:",
  "schedule": ["* * 1,15 * *"],
  "packageRules": [
    {
      "description": "Only semver patch (Z in X.Y.Z) for Docker base images and pip requirements files",
      "matchManagers": ["dockerfile", "pip_requirements"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "description": "Full semver (X.Y.Z) for qubership-envgene-base-modules base image",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["ghcr.io/netcracker/qubership-envgene-base-modules"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": true
    },
    {
      "description": "Apk pins (Repology regex): only patch updates",
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["repology"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "description": "Do not bump cython (repo keeps cython<3 in constraint.txt)",
      "matchPackageNames": ["cython"],
      "enabled": false
    },
    {
      "description": "One PR for all Dockerfile + requirements + Alpine pins",
      "matchManagers": ["dockerfile", "pip_requirements", "custom.regex"],
      "groupName": "docker-and-python-deps"
    }
  ]
}
