{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Secret Stores configuration",
  "description": "Instance repository configuration for external secret stores used by external Credentials. See /docs/features/external-creds.md",
  "additionalProperties": {
    "type": "object",
    "required": ["type", "url"],
    "additionalProperties": false,
    "properties": {
      "type": {
        "type": "string",
        "enum": ["vault", "azure", "aws", "gcp"],
        "description": "Backend type"
      },
      "url": {
        "type": "string",
        "description": "Endpoint or connection URL for the store"
      },
      "mountPath": {
        "type": "string",
        "description": "Required when type is vault (KV mount path)"
      },
      "vaultName": {
        "type": "string",
        "description": "Required when type is azure"
      },
      "region": {
        "type": "string",
        "description": "Required when type is aws"
      },
      "projectId": {
        "type": "string",
        "description": "Required when type is gcp"
      }
    },
    "allOf": [
      {
        "if": { "properties": { "type": { "const": "vault" } } },
        "then": { "required": ["mountPath"] }
      },
      {
        "if": { "properties": { "type": { "const": "azure" } } },
        "then": { "required": ["vaultName"] }
      },
      {
        "if": { "properties": { "type": { "const": "aws" } } },
        "then": { "required": ["region"] }
      },
      {
        "if": { "properties": { "type": { "const": "gcp" } } },
        "then": { "required": ["projectId"] }
      }
    ]
  }
}
